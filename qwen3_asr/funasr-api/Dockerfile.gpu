# 1. 使用已经验证可运行的 ARM64 vLLM 镜像作为基础底座
# dgx gb10选择是cu130，根据显卡进行设置
FROM docker.1ms.run/vllm/vllm-openai:latest-cu130

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    HF_HUB_DISABLE_SYMLINKS_WARNING=1 \
    HF_HUB_DISABLE_PROGRESS_BARS=1 \
    PIP_BREAK_SYSTEM_PACKAGES=1

# 切换为 root 用户以确保有权限安装系统软件
USER root

# 2. 安装 FunASR 需要的音频处理依赖，顺便装上 dos2unix 用于格式化换行符
# 在安装列表中增加了 openssl，用于在 entrypoint 启动时自动生成 HTTPS 证书
RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg \
        sox \
        libsox-dev \
        libsndfile1 \
        nginx \
        dos2unix \
        openssl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 3. 拷贝依赖文件并进行安全处理
COPY requirements.txt /tmp/requirements.txt

# 【核心防护】：从依赖列表中强行剔除 vllm
# 防止 pip 下载覆盖掉当前基础镜像里极其珍贵的 ARM 版 vllm
RUN sed -i '/vllm/d' /tmp/requirements.txt 

# 4. 安装 Python 依赖
# 先安装 requirements 里除了 vllm 之外的其他通用包
RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple -r /tmp/requirements.txt

# 【核心修复】：单独补装 Qwen 引擎依赖，且严格限制不牵连底层包
RUN pip install --no-deps qwen-asr -i https://pypi.tuna.tsinghua.edu.cn/simple \
    && pip install nagisa -i https://pypi.tuna.tsinghua.edu.cn/simple

# 5. 拷贝所有项目源码
COPY . .

# 6. 终极免疫与权限设置
# 创建运行目录 -> 强制转换文件换行符(彻底根除 \r 报错) -> 赋予执行权限
RUN mkdir -p /app/temp /app/data /app/logs \
    && dos2unix scripts/docker/entrypoint.sh start.py \
    && chmod +x start.py scripts/docker/entrypoint.sh

# 全局环境变量锁死单工作进程，彻底根绝双倍显存占用漏洞
ENV WORKERS=1 \
    WEB_CONCURRENCY=1

EXPOSE 8000

ENTRYPOINT ["/app/scripts/docker/entrypoint.sh"]
CMD ["python3", "start.py"]